# Sao chép file này thành .env.local và điền giá trị thật.
# KHÔNG commit file .env.local lên GitHub.

# Chuỗi kết nối Neon Postgres
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Khóa bí mật để ký token đăng nhập (tạo bằng: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET="thay-bang-chuoi-ngau-nhien-cua-ban"

# Mã mời để đăng ký tài khoản mới (ai biết mã này mới đăng ký được)
INVITE_CODE="dat-mot-ma-bi-mat"

# URL gốc của web để tạo link trong email (vd: https://ten-app.vercel.app). Local có thể để http://localhost:3000
APP_URL="http://localhost:3000"

# Cấu hình SMTP để gửi email quên mật khẩu. Ví dụ với Gmail (cần bật 2FA + tạo App Password):
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="email-cua-ban@gmail.com"
SMTP_PASS="app-password-16-ky-tu"
SMTP_FROM="Quản Lý Task <email-cua-ban@gmail.com>"
